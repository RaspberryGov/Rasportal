<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Polymarket Copy-Trade Terminal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: #1a1c23; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #3f4451; border-radius: 10px; }
        @keyframes pulse-border {
            0% { border-color: rgba(59, 130, 246, 0.5); }
            50% { border-color: rgba(59, 130, 246, 1); }
            100% { border-color: rgba(59, 130, 246, 0.5); }
        }
        .status-active { animation: pulse-border 2s infinite; }
        .input-dark { @apply bg-black border border-gray-800 rounded px-2 py-1.5 text-[10px] text-white outline-none focus:border-blue-500 transition-colors; }
    </style>
</head>
<body class="bg-[#0b0e14] text-slate-200 font-sans p-4">
    <div class="max-w-[1600px] mx-auto">
        
        <div class="mb-6 bg-[#161b22] border border-blue-500/30 rounded-xl p-4 shadow-2xl">
            <div class="flex items-center justify-between mb-4">
                <div class="flex items-center gap-2">
                    <div id="bot-status-dot" class="h-2 w-2 bg-gray-600 rounded-full"></div>
                    <h2 class="text-xs font-black uppercase tracking-[0.2em] text-blue-400">Copy-Trade Terminal v1.0</h2>
                </div>
                <div class="text-[9px] text-gray-500 font-mono">ENCRYPTED LOCAL SESSION</div>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4 items-end">
                <div class="flex flex-col gap-1">
                    <label class="text-[8px] uppercase font-bold text-gray-500">API Passphrase</label>
                    <input type="password" id="api-pass" placeholder="..." class="input-dark bg-black border border-gray-800 rounded px-2 py-1.5 text-[10px]">
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-[8px] uppercase font-bold text-gray-500">Take Profit %</label>
                    <input type="number" id="tp-percent" value="10" class="input-dark bg-black border border-gray-800 rounded px-2 py-1.5 text-[10px]">
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-[8px] uppercase font-bold text-gray-500">Stop Loss %</label>
                    <input type="number" id="sl-percent" value="5" class="input-dark bg-black border border-gray-800 rounded px-2 py-1.5 text-[10px]">
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-[8px] uppercase font-bold text-gray-500">Order Size ($)</label>
                    <input type="number" id="trade-size" value="50" class="input-dark bg-black border border-gray-800 rounded px-2 py-1.5 text-[10px]">
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-[8px] uppercase font-bold text-gray-500">Slippage %</label>
                    <input type="number" id="slippage" value="1" step="0.1" class="input-dark bg-black border border-gray-800 rounded px-2 py-1.5 text-[10px]">
                </div>
                <div class="flex flex-col gap-1">
                    <label class="text-[8px] uppercase font-bold text-gray-500">Market Target</label>
                    <select id="market-time" class="input-dark bg-black border border-gray-800 rounded px-2 py-1.5 text-[10px] cursor-pointer">
                        <option value="5m">BTC 5m Price</option>
                        <option value="15m" selected>BTC 15m Price</option>
                    </select>
                </div>
                <button id="bot-toggle" onclick="toggleBot()" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-black text-[10px] py-2 rounded uppercase transition-all">
                    Start Copying
                </button>
            </div>
        </div>

        <header class="flex flex-col mb-6 gap-4">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="flex items-center gap-4">
                    <h1 class="text-xl font-black text-white italic tracking-tighter">@RENAME <span class="text-blue-500">MONITOR</span></h1>
                    <div id="status-bar" class="text-[9px] font-mono text-gray-500 bg-gray-900 px-3 py-1 rounded-full border border-gray-800 uppercase tracking-widest status-active">
                        Initializing...
                    </div>
                </div>

                <div class="flex items-center bg-[#161b22] border border-gray-800 rounded-lg p-1 w-full md:w-auto shadow-xl">
                    <button onclick="toggleFavorite()" id="fav-btn" class="px-2 text-gray-500 hover:text-yellow-400 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="star-icon">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.921-.755 1.688-1.54 1.118l-3.976-2.888a1 1 0 00-1.175 0l-3.976 2.888c-.784.57-1.838-.197-1.539-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                        </svg>
                    </button>
                    <input type="text" id="wallet-input" placeholder="0x..." class="bg-transparent text-[11px] font-mono px-3 py-1.5 w-full md:w-80 outline-none text-blue-400" value="0xf6963d4cdbb6f26d753bda303e9513132afb1b7d">
                    <button onclick="updateUser()" class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-bold px-4 py-1.5 rounded transition uppercase ml-1">Switch</button>
                </div>
            </div>
            <div id="favorites-container" class="flex flex-wrap items-center gap-2 py-2 border-y border-gray-800/50">
                <span class="text-[9px] font-bold text-gray-600 uppercase tracking-widest mr-2">Favourited:</span>
                <div id="favorites-list" class="flex flex-wrap gap-2"></div>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="flex flex-col h-[70vh]">
                <h2 class="bg-orange-500/10 text-orange-500 text-[10px] font-black p-2 mb-2 rounded border border-orange-500/20 text-center uppercase">Bitcoin</h2>
                <div id="col-btc" class="space-y-3 overflow-y-auto custom-scrollbar flex-1 pr-1"></div>
            </div>
            <div class="flex flex-col h-[70vh]">
                <h2 class="bg-blue-500/10 text-blue-500 text-[10px] font-black p-2 mb-2 rounded border border-blue-500/20 text-center uppercase">Ethereum</h2>
                <div id="col-eth" class="space-y-3 overflow-y-auto custom-scrollbar flex-1 pr-1"></div>
            </div>
            <div class="flex flex-col h-[70vh]">
                <h2 class="bg-purple-500/10 text-purple-500 text-[10px] font-black p-2 mb-2 rounded border border-purple-500/20 text-center uppercase">Solana</h2>
                <div id="col-sol" class="space-y-3 overflow-y-auto custom-scrollbar flex-1 pr-1"></div>
            </div>
            <div class="flex flex-col h-[70vh]">
                <h2 class="bg-teal-500/10 text-teal-500 text-[10px] font-black p-2 mb-2 rounded border border-teal-500/20 text-center uppercase">XRP</h2>
                <div id="col-xrp" class="space-y-3 overflow-y-auto custom-scrollbar flex-1 pr-1"></div>
            </div>
        </div>
    </div>

    <script>
        let CURRENT_USER = "0xf6963d4cdbb6f26d753bda303e9513132afb1b7d";
        let botActive = false;
        const ASSETS = ['btc', 'eth', 'sol', 'xrp'];
        let favorites = JSON.parse(localStorage.getItem('poly_favorites') || '[]');

        function toggleBot() {
            botActive = !botActive;
            const btn = document.getElementById('bot-toggle');
            const dot = document.getElementById('bot-status-dot');
            if(botActive) {
                btn.innerText = "Stop Copying";
                btn.classList.replace('bg-blue-600', 'bg-red-600');
                dot.classList.replace('bg-gray-600', 'bg-green-500');
                dot.classList.add('animate-ping');
            } else {
                btn.innerText = "Start Copying";
                btn.classList.replace('bg-red-600', 'bg-blue-600');
                dot.classList.replace('bg-green-500', 'bg-gray-600');
                dot.classList.remove('animate-ping');
            }
        }

        async function sync() {
            try {
                const response = await fetch(`https://data-api.polymarket.com/activity?user=${CURRENT_USER}&limit=10`);
                const data = await response.json();
                ASSETS.forEach(id => document.getElementById(`col-${id}`).innerHTML = '');
                data.forEach(item => {
                    const title = item.title.toLowerCase();
                    let targetCol = null;
                    if (title.includes('btc') || title.includes('bitcoin')) targetCol = 'btc';
                    else if (title.includes('eth') || title.includes('ethereum')) targetCol = 'eth';
                    else if (title.includes('solana') || title.includes('sol')) targetCol = 'sol';
                    else if (title.includes('xrp')) targetCol = 'xrp';
                    if (targetCol) document.getElementById(`col-${targetCol}`).insertAdjacentHTML('beforeend', createCard(item));
                });
                document.getElementById('status-bar').innerText = `LIVE UPDATED: ${new Date().toLocaleTimeString()}`;
            } catch (err) { console.error(err); }
        }

        function createCard(item) {
            let direction = (item.outcomeIndex === "0" || item.outcome?.toLowerCase() === "yes") ? "UP" : "DOWN";
            const isBuy = item.side === 'BUY';
            const polyLink = `https://polymarket.com/event/${item.slug}`;
            return `<div class="bg-[#161b22] border border-gray-800 rounded-lg p-3 hover:border-gray-500 transition-all group">
                <div class="flex justify-between items-start mb-2">
                    <span class="text-[9px] font-bold ${isBuy ? 'text-green-500' : 'text-red-400'} uppercase">${item.side}</span>
                    <span class="text-[9px] text-gray-600">${new Date(item.timestamp * 1000).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</span>
                </div>
                <a href="${polyLink}" target="_blank" class="block text-[11px] font-medium text-gray-300 mb-3 hover:text-blue-400 transition-colors">${item.title}</a>
                <div class="flex justify-between items-end bg-black/40 p-2 rounded border border-gray-800/50">
                    <div><div class="text-[8px] text-gray-500 uppercase font-bold">Pos</div><div class="text-sm font-black ${direction === 'UP' ? 'text-green-400' : 'text-red-400'}">${direction}</div></div>
                    <div class="text-right"><div class="text-[8px] text-gray-500 uppercase font-bold">Val</div><div class="text-xs font-mono font-bold text-white">$${parseFloat(item.usdcSize).toFixed(2)}</div></div>
                </div>
            </div>`;
        }

        function init() { renderFavorites(); sync(); setInterval(sync, 10000); }
        function renderFavorites() { /* Existing logic */ }
        function updateUser(a) { /* Existing logic */ }
        init();
    </script>
</body>
</html>
